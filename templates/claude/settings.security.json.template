{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_harness_template": "claude/settings.security.json.template",
  "_harness_version": "3.17.1",
  "_harness_note": "Project-level settings template. Plugin defaults (.claude-plugin/settings.json) provide baseline deny/ask; this template adds defense-in-depth at project scope.",
  "_harness_auto_mode_note": "Auto Mode guidance: keep \"$defaults\" and append only project-specific entries. Do not replace built-in Auto Mode defaults or relax permissions.deny, permissions.ask, or sandbox guardrails.",
  "language": "japanese",
  "permissions": {
    "allow": [
      "Bash(npm test:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run build:*)",
      "Bash(bun test:*)",
      "Bash(bun run lint:*)",
      "Bash(bun run build:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm run lint:*)",
      "Bash(pnpm run build:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)",
      "Bash(mongo:*)",
      "mcp__codex__*",
      "Edit(.claude/settings*)",
      "Write(.claude/settings*)",
      "MultiEdit(.claude/settings*)",
      "Edit(.claude-plugin/settings*)",
      "Write(.claude-plugin/settings*)",
      "MultiEdit(.claude-plugin/settings*)",
      "Edit(.eslintrc*)",
      "Write(.eslintrc*)",
      "MultiEdit(.eslintrc*)",
      "Edit(eslint.config.*)",
      "Write(eslint.config.*)",
      "MultiEdit(eslint.config.*)",
      "Edit(biome.json)",
      "Write(biome.json)",
      "MultiEdit(biome.json)",
      "Edit(tsconfig*.json)",
      "Write(tsconfig*.json)",
      "MultiEdit(tsconfig*.json)",
      "Edit(.github/workflows/*)",
      "Write(.github/workflows/*)",
      "MultiEdit(.github/workflows/*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*id_rsa*)",
      "Read(**/*id_ed25519*)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/**)",
      "Read(**/.npmrc)"
    ],
    "ask": [
      "Bash(rm -r:*)",
      "Bash(git reset --hard:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git clean -fx:*)",
      "Bash(git rebase:*)",
      "Bash(git merge:*)",
      "Bash(npm install:*)",
      "Bash(npm exec:*)",
      "Bash(npx:*)",
      "Bash(bun install:*)",
      "Bash(pnpm install:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run start:*)",
      "Bash(bun run dev:*)",
      "Bash(bun run start:*)"
    ]
  },
  "sandbox": {
    "failIfUnavailable": true,
    "network": {
      "deniedDomains": [
        "169.254.169.254",
        "metadata.google.internal",
        "metadata.azure.com",
        "pastebin.com",
        "transfer.sh",
        "0x0.st",
        "paste.ee",
        "termbin.com",
        "ix.io"
      ]
    },
    "filesystem": {
      "denyRead": [
        ".env",
        ".env.*",
        "!.env.example",
        "secrets/**",
        "**/*.pem",
        "**/*.key",
        "**/*id_rsa*",
        "**/*id_ed25519*",
        "**/.aws/**",
        "**/.ssh/**"
      ],
      "allowRead": [
        ".env.example",
        ".env.sample",
        "config/public-*",
        "docs/**"
      ]
    }
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "autoMode": {
    "hard_deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "mcp__codex__*"
    ]
  }
}
