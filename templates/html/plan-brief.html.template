<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="utf-8">
<title>Plan Brief: {{user_request}}</title>
<style>
  /* Claude Harness Brand palette */
  :root {
    --harness-bg:     #FAFAFA;
    --harness-fg:     #0F0F0F;
    --harness-orange: #F58A4A;
    --harness-muted:  #6B6B6B;
    --harness-line:   #E5E5E5;
    --harness-warn:   #C25030;
    --harness-info:   #3D6B9A;
  }
  * { box-sizing: border-box; }
  html, body {
    margin: 0;
    padding: 0;
    background: var(--harness-bg);
    color: var(--harness-fg);
    font-family: "Inter", "Noto Sans JP", system-ui, sans-serif;
    font-weight: 400;
    line-height: 1.7;
  }
  main {
    max-width: 760px;
    margin: 0 auto;
    padding: 56px 32px 96px;
  }
  header.brief-header {
    margin-bottom: 40px;
    padding-bottom: 16px;
    border-bottom: 2px solid var(--harness-orange);
  }
  header.brief-header .label {
    display: inline-block;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--harness-orange);
    margin-bottom: 8px;
  }
  header.brief-header h1 {
    font-weight: 600;
    font-size: 24px;
    margin: 0 0 8px 0;
    line-height: 1.4;
  }
  header.brief-header .meta {
    color: var(--harness-muted);
    font-size: 13px;
  }
  section.brief-section {
    margin-bottom: 36px;
  }
  section.brief-section h2 {
    font-weight: 600;
    font-size: 16px;
    margin: 0 0 12px 0;
    color: var(--harness-fg);
  }
  section.brief-section .body {
    color: var(--harness-fg);
    white-space: pre-wrap;
  }
  ul.cards {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  ul.cards li {
    padding: 12px 16px;
    border-left: 3px solid var(--harness-orange);
    background: #fff;
    margin-bottom: 8px;
  }
  ul.cards li .name {
    font-weight: 600;
    margin-bottom: 4px;
  }
  ul.cards li .summary {
    color: var(--harness-muted);
    font-size: 14px;
  }
  ul.risks li {
    border-left: 3px solid var(--harness-warn);
  }
  ul.risks li .severity {
    display: inline-block;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 1px 8px;
    border-radius: 2px;
    background: var(--harness-warn);
    color: #fff;
    margin-right: 8px;
    vertical-align: middle;
  }
  ul.refs li {
    border-left: 3px solid var(--harness-info);
  }
  ul.refs li .id {
    color: var(--harness-info);
    font-weight: 600;
    margin-right: 6px;
  }
  ul.evidence {
    list-style: disc;
    padding-left: 24px;
    color: var(--harness-muted);
    font-size: 13px;
  }
  .confidence-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }
  .confidence-bar .num {
    font-weight: 600;
    font-size: 28px;
    color: var(--harness-fg);
    min-width: 60px;
  }
  .confidence-bar .num small {
    font-size: 14px;
    font-weight: 400;
    color: var(--harness-muted);
  }
  .confidence-bar .track {
    flex: 1;
    height: 8px;
    background: var(--harness-line);
    border-radius: 4px;
    overflow: hidden;
  }
  .confidence-bar .fill {
    height: 100%;
    background: var(--harness-orange);
  }
  footer.brief-footer {
    margin-top: 56px;
    padding-top: 16px;
    border-top: 1px solid var(--harness-line);
    color: var(--harness-muted);
    font-size: 12px;
  }
</style>
</head>
<body>
<main>
  <header class="brief-header">
    <span class="label">Plan Brief</span>
    <h1>{{user_request}}</h1>
    <div class="meta">{{project}} &middot; {{generated_at}}</div>
  </header>

  <section class="brief-section">
    <h2>理解</h2>
    <div class="body">{{my_understanding}}</div>
  </section>

  <section class="brief-section">
    <h2>選択肢</h2>
    <ul class="cards">{{#options}}
      <li>
        <div class="name">{{name}}</div>
        <div class="summary">{{summary}}</div>
      </li>{{/options}}
    </ul>
  </section>

  <section class="brief-section">
    <h2>リスク</h2>
    <ul class="cards risks">{{#risks}}
      <li>
        <span class="severity">{{severity}}</span>
        <span class="name">{{kind}}</span>
        <div class="summary">{{description}}</div>
      </li>{{/risks}}
    </ul>
  </section>

  <section class="brief-section">
    <h2>受け入れ条件</h2>
    <ul class="cards">{{#acceptance_criteria}}
      <li>
        <div class="name">{{id}}</div>
        <div class="summary">{{description}}</div>
      </li>{{/acceptance_criteria}}
    </ul>
  </section>

  <section class="brief-section">
    <h2>確信度</h2>
    <div class="confidence-bar">
      <div class="num">{{confidence}}<small> / 100</small></div>
      <div class="track"><div class="fill" style="width: {{confidence}}%"></div></div>
    </div>
    <ul class="evidence">{{#confidence_evidence_items}}
      <li>{{text}}</li>{{/confidence_evidence_items}}
    </ul>
  </section>

  <section class="brief-section">
    <h2>関連する過去 Decision</h2>
    <ul class="cards refs">{{#related_decisions}}
      <li>
        <span class="id">{{id}}</span>
        <span class="name">{{title}}</span>
        <div class="summary">{{relevance}}</div>
      </li>{{/related_decisions}}
    </ul>
  </section>

  <section class="brief-section">
    <h2>類似する過去 Plans</h2>
    <ul class="cards refs">{{#similar_past_plans}}
      <li>
        <span class="id">{{phase}}</span>
        <span class="name">{{archive_path}}</span>
        <div class="summary">{{outcome}} &middot; {{relevance}}</div>
      </li>{{/similar_past_plans}}
    </ul>
  </section>

  <footer class="brief-footer">
    plan-brief-context.v1 &middot; project: {{project}} &middot; generated_at: {{generated_at}}
  </footer>
</main>
</body>
</html>
